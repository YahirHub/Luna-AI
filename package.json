{
  "name": "whatsapp-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run prepare:media && bun run src/index.ts",
    "dev": "bun run prepare:media && bun --watch run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "build": "bun run prepare:media && bun build ./src/index.ts --compile --bytecode --compile-exec-argv=--no-warnings --asset-naming=\"[name].[ext]\" --outfile ./dist/luna-ai && bun run package:runtime",
    "prepare:media": "bun run scripts/prepare-media-assets.ts",
    "package:runtime": "bun run scripts/package-runtime.ts"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "qrcode": "1.5.4",
    "pino": "10.3.1",
    "@tesseract.js-data/spa": "1.0.0",
    "jpeg-js": "0.4.4",
    "ogg-opus-decoder": "1.7.3",
    "pngjs": "7.0.0",
    "tesseract-wasm": "0.11.0",
    "@twemoji/parser": "15.0.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/qrcode": "1.5.6",
    "typescript": "5.7.3",
    "@types/pngjs": "6.0.5"
  },
  "packageManager": "bun@1.3.14",
  "patchedDependencies": {
    "ogg-opus-decoder@1.7.3": "patches/ogg-opus-decoder@1.7.3.patch"
  }
}
