{
  "name": "whatsapp-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/index.ts --compile --bytecode --compile-exec-argv=--no-warnings --outfile ./dist/whatsapp-bot.exe"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "qrcode": "1.5.4",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/qrcode": "1.5.6",
    "typescript": "5.7.3"
  },
  "packageManager": "bun@1.3.14"
}
